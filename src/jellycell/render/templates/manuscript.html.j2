<!DOCTYPE html>
<html lang="en" data-jc-page="manuscript">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="generator" content="jellycell">
<meta name="jellycell:manuscript" content="{{ md_rel }}">
<title>{{ md_title }} — {{ project_name }}</title>
<style>
{% include "partials/styles.css.j2" %}
</style>
<style>
{{ pygments_css|safe }}
</style>
</head>
<body class="jc-layout">
<header class="jc-header">
  <nav class="jc-breadcrumb">
    <a href="/">{{ project_name }}</a>
    <span class="sep">/</span>
    <a href="/manuscripts/">manuscripts</a>
    <span class="sep">/</span>
    <span>{{ md_rel }}</span>
  </nav>
  {% if tearsheet_for %}
  <nav class="jc-prevnext">
    <a class="jc-next" href="/nb/{{ tearsheet_for }}" title="View the source notebook">
      Notebook →
    </a>
  </nav>
  {% elif prev_link or next_link %}
  <nav class="jc-prevnext">
    {% if prev_link %}
    <a class="jc-prev" href="{{ prev_link.href }}" title="Previous tearsheet">← {{ prev_link.title }}</a>
    {% endif %}
    {% if next_link %}
    <a class="jc-next" href="{{ next_link.href }}" title="Next tearsheet">{{ next_link.title }} →</a>
    {% endif %}
  </nav>
  {% endif %}
</header>
<div class="jc-shell">
  <aside class="jc-sidebar" aria-label="Manuscript navigation">
    {% if catalog.authored %}
    <section>
      <h3>Authored</h3>
      <ul class="jc-sibling-list">
        {% for link in catalog.authored %}
        <li>
          <a href="{{ link.href }}"{% if link.current %} aria-current="page"{% endif %}>
            {{ link.title }}
          </a>
        </li>
        {% endfor %}
      </ul>
    </section>
    {% endif %}
    {% if catalog.tearsheets %}
    <section>
      <h3>Tearsheets</h3>
      <ul class="jc-sibling-list">
        {% for link in catalog.tearsheets %}
        <li>
          <a href="{{ link.href }}"{% if link.current %} aria-current="page"{% endif %}>
            {{ link.title }}
          </a>
        </li>
        {% endfor %}
      </ul>
    </section>
    {% endif %}
    {% if catalog.journal %}
    <section>
      <h3>Log</h3>
      <ul class="jc-sibling-list">
        <li>
          <a href="{{ catalog.journal.href }}"{% if catalog.journal.current %} aria-current="page"{% endif %}>
            {{ catalog.journal.title }}
          </a>
        </li>
      </ul>
    </section>
    {% endif %}
  </aside>
  <main class="jc-main">
    <article class="jc-manuscript">
      <header class="jc-title">
        <h1>{{ md_title }}</h1>
        <p class="jc-path">manuscripts/{{ md_rel }}</p>
      </header>
      <section class="jc-md-body">
{{ body_html|safe }}
      </section>
    </article>
  </main>
</div>
<footer class="jc-footer">
  <span>Generated by <a href="https://jellycell.readthedocs.io">jellycell</a></span>
</footer>
<script>
{% include "partials/script.js.j2" %}
</script>
</body>
</html>
