<!DOCTYPE html>
<html lang="en" data-jc-page="manuscripts-index">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="generator" content="jellycell">
<title>Manuscripts — {{ project_name }}</title>
<style>
{% include "partials/styles.css.j2" %}
</style>
<style>
{{ pygments_css|safe }}
</style>
</head>
<body class="jc-layout">
<header class="jc-header">
  <nav class="jc-breadcrumb">
    <a href="/">{{ project_name }}</a>
    <span class="sep">/</span>
    <span>manuscripts</span>
  </nav>
</header>
<div class="jc-shell jc-shell-index">
  <main class="jc-main">
    <article class="jc-index">
      <header class="jc-title">
        <h1>Manuscripts</h1>
        <p class="jc-subtitle">
          Authored writeups live at the root of <code>manuscripts/</code>;
          auto-generated tearsheets under <code>tearsheets/</code>.
        </p>
      </header>

      {% if catalog.authored %}
      <section class="jc-notebooks">
        <h2>Authored</h2>
        <ul class="jc-list">
          {% for link in catalog.authored %}
          <li>
            <a class="jc-list-item" href="{{ link.href }}">
              <span class="jc-list-title">{{ link.title }}</span>
              <span class="jc-list-path">manuscripts/{{ link.rel }}</span>
            </a>
          </li>
          {% endfor %}
        </ul>
      </section>
      {% endif %}

      {% if catalog.tearsheets %}
      <section class="jc-notebooks">
        <h2>Tearsheets</h2>
        <ul class="jc-list">
          {% for link in catalog.tearsheets %}
          <li>
            <a class="jc-list-item" href="{{ link.href }}">
              <span class="jc-list-title">{{ link.title }}</span>
              <span class="jc-list-path">manuscripts/{{ link.rel }}</span>
            </a>
          </li>
          {% endfor %}
        </ul>
      </section>
      {% endif %}

      {% if catalog.journal %}
      <section class="jc-notebooks">
        <h2>Log</h2>
        <ul class="jc-list">
          <li>
            <a class="jc-list-item" href="{{ catalog.journal.href }}">
              <span class="jc-list-title">{{ catalog.journal.title }}</span>
              <span class="jc-list-path">append-only run log</span>
            </a>
          </li>
        </ul>
      </section>
      {% endif %}

      {% if not catalog.has_any %}
      <p class="jc-empty">
        Nothing here yet. Run
        <code>jellycell export tearsheet notebooks/&lt;name&gt;.py</code> to
        drop a tearsheet into <code>manuscripts/tearsheets/</code>, or write
        a hand-authored <code>manuscripts/&lt;name&gt;.md</code>.
      </p>
      {% endif %}
    </article>
  </main>
</div>
<footer class="jc-footer">
  <span>Generated by <a href="https://jellycell.readthedocs.io">jellycell</a></span>
</footer>
<script>
{% include "partials/script.js.j2" %}
</script>
</body>
</html>
