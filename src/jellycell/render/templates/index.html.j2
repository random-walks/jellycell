<!DOCTYPE html>
<html lang="en" data-jc-page="index">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="generator" content="jellycell">
<title>{{ project_name }} — jellycell catalogue</title>
<style>
{% include "partials/styles.css.j2" %}
</style>
<style>
{{ pygments_css|safe }}
</style>
</head>
<body class="jc-layout">
<header class="jc-header">
  <nav class="jc-breadcrumb">
    <span>{{ project_name }}</span>
  </nav>
</header>
<div class="jc-shell jc-shell-index">
  <main class="jc-main">
    <article class="jc-index">
      <header class="jc-title">
        <h1>{{ project_name }}</h1>
        <p class="jc-subtitle">Notebook catalogue</p>
      </header>

    <section class="jc-notebooks">
      <h2>Notebooks</h2>
      {% if notebooks %}
      <ul class="jc-list">
        {% for nb in notebooks %}
        <li>
          <a class="jc-list-item" href="{{ nb.href }}">
            <span class="jc-list-title">{{ nb.title }}</span>
            <span class="jc-list-meta">
              {{ nb.cell_count }} cached cells
              {% if nb.last_run %}· last run {{ nb.last_run }}{% endif %}
            </span>
            <span class="jc-list-path">{{ nb.path }}</span>
          </a>
        </li>
        {% endfor %}
      </ul>
      {% else %}
      <p class="jc-empty">No notebooks found under <code>notebooks/</code>.</p>
      {% endif %}
    </section>

    {% if catalog and catalog.has_any %}
    <section class="jc-notebooks">
      <h2>Manuscripts</h2>
      <p class="jc-subtitle">
        Authored writeups + auto-generated tearsheets.
        <a href="/manuscripts/">browse all →</a>
      </p>
      <ul class="jc-list">
        {% for link in catalog.authored %}
        <li>
          <a class="jc-list-item" href="{{ link.href }}">
            <span class="jc-list-title">{{ link.title }}</span>
            <span class="jc-list-meta">authored</span>
            <span class="jc-list-path">manuscripts/{{ link.rel }}</span>
          </a>
        </li>
        {% endfor %}
        {% for link in catalog.tearsheets %}
        <li>
          <a class="jc-list-item" href="{{ link.href }}">
            <span class="jc-list-title">{{ link.title }}</span>
            <span class="jc-list-meta">tearsheet</span>
            <span class="jc-list-path">manuscripts/{{ link.rel }}</span>
          </a>
        </li>
        {% endfor %}
        {% if catalog.journal %}
        <li>
          <a class="jc-list-item" href="{{ catalog.journal.href }}">
            <span class="jc-list-title">{{ catalog.journal.title }}</span>
            <span class="jc-list-meta">run log (append-only)</span>
            <span class="jc-list-path">manuscripts/{{ catalog.journal.rel }}</span>
          </a>
        </li>
        {% endif %}
      </ul>
    </section>
    {% endif %}

    {% if recent_runs %}
    <section class="jc-recent">
      <h2>Recent runs</h2>
      <table class="jc-recent-table">
        <thead>
          <tr>
            <th>Notebook</th>
            <th>Cell</th>
            <th>Status</th>
            <th>When</th>
            <th>ms</th>
          </tr>
        </thead>
        <tbody>
        {% for row in recent_runs %}
          <tr>
            <td><a href="{{ row.href }}">{{ row.notebook }}</a></td>
            <td>{{ row.cell_id }}{% if row.cell_name %} ({{ row.cell_name }}){% endif %}</td>
            <td>
              <span class="jc-status jc-status-{{ row.status }}">{{ row.status }}</span>
            </td>
            <td>{{ row.executed_at }}</td>
            <td class="jc-num">{{ row.duration_ms }}</td>
          </tr>
        {% endfor %}
        </tbody>
      </table>
    </section>
    {% endif %}
    </article>
  </main>
</div>
<footer class="jc-footer">
  <span>Generated by <a href="https://jellycell.readthedocs.io">jellycell</a></span>
</footer>
<script>
{% include "partials/script.js.j2" %}
</script>
</body>
</html>
