<!DOCTYPE html>
<html lang="en" data-jc-page="notebook">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="generator" content="jellycell">
<meta name="jellycell:notebook" content="{{ notebook }}">
<title>{{ title }} — {{ project_name }}</title>
<style>
{% include "partials/styles.css.j2" %}
</style>
<style>
{{ pygments_css|safe }}
</style>
</head>
<body class="jc-layout">
<header class="jc-header">
  <nav class="jc-breadcrumb">
    <a href="index.html">{{ project_name }}</a>
    <span class="sep">/</span>
    <span>{{ notebook }}</span>
  </nav>
  <nav class="jc-prevnext">
    {% if prev_nb %}
    <a class="jc-prev" href="{{ prev_nb.href }}" title="Previous notebook">← {{ prev_nb.title }}</a>
    {% endif %}
    {% if next_nb %}
    <a class="jc-next" href="{{ next_nb.href }}" title="Next notebook">{{ next_nb.title }} →</a>
    {% endif %}
  </nav>
</header>
<div class="jc-shell">
  <aside class="jc-sidebar" aria-label="Notebook navigation">
    {% if toc %}
    <section>
      <h3>Contents</h3>
      <ul class="jc-toc">
        {% for item in toc %}
        <li class="jc-toc-lvl-{{ item.level }} jc-toc-{{ item.kind }}">
          <a href="#{{ item.anchor }}">{{ item.label }}</a>
        </li>
        {% endfor %}
      </ul>
    </section>
    {% endif %}
    {% if siblings and siblings|length > 1 %}
    <section>
      <h3>Notebooks</h3>
      <ul class="jc-sibling-list">
        {% for sib in siblings %}
        <li>
          <a href="{{ sib.href }}"{% if sib.current %} aria-current="page"{% endif %}>
            {{ sib.title }}
          </a>
        </li>
        {% endfor %}
      </ul>
    </section>
    {% endif %}
  </aside>
  <main class="jc-main">
    <article class="jc-notebook">
      <header class="jc-title">
        <h1>{{ title }}</h1>
        <p class="jc-path">{{ notebook }}</p>
      </header>
      <section class="jc-cells">
{{ cells_html|safe }}
      </section>
    </article>
  </main>
</div>
<footer class="jc-footer">
  <span>Generated by <a href="https://jellycell.readthedocs.io">jellycell</a></span>
</footer>
<script>
{% include "partials/script.js.j2" %}
</script>
</body>
</html>
